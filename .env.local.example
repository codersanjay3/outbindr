# PitchWars — API keys are entered in-app via the ⚙ gear icon.
# This file can remain empty. No server-side keys are required.
# Keys are stored in your browser's localStorage and sent as request headers.

# Optional: uncomment to pre-fill a default key (overridden by in-app keys)
# ANTHROPIC_API_KEY=sk-ant-...
# GROQ_API_KEY=gsk_...
# ELEVENLABS_API_KEY=...
